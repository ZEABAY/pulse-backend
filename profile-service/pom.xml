<?xml version="1.0" encoding="UTF-8"?>
<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="http://maven.apache.org/POM/4.0.0"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">

    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.zeabay.pulse</groupId>
        <artifactId>pulse-backend</artifactId>
        <version>0.0.1-SNAPSHOT</version>
        <relativePath>../pom.xml</relativePath>
    </parent>

    <artifactId>profile-service</artifactId>
    <name>profile-service</name>
    <description>User profile management — avatar upload, profile CRUD, event-driven sync</description>

    <dependencies>
        <!-- Persistence -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-r2dbc</artifactId>
        </dependency>

        <dependency>
            <groupId>org.springframework.cloud</groupId>
            <artifactId>spring-cloud-starter-consul-discovery</artifactId>
        </dependency>

        <!-- Pulse shared: domain events, topic constants, topic creation -->
        <dependency>
            <groupId>com.zeabay.pulse</groupId>
            <artifactId>pulse-shared</artifactId>
            <version>${project.version}</version>
        </dependency>

        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <scope>runtime</scope>
        </dependency>
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>r2dbc-postgresql</artifactId>
            <scope>runtime</scope>
        </dependency>
        <dependency>
            <groupId>org.flywaydb</groupId>
            <artifactId>flyway-core</artifactId>
        </dependency>
        <dependency>
            <groupId>org.flywaydb</groupId>
            <artifactId>flyway-database-postgresql</artifactId>
        </dependency>

        <!-- zeabay-common -->
        <dependency>
            <groupId>com.zeabay</groupId>
            <artifactId>zeabay-webflux</artifactId>
        </dependency>
        <dependency>
            <groupId>com.zeabay</groupId>
            <artifactId>zeabay-openapi</artifactId>
        </dependency>
        <dependency>
            <groupId>com.zeabay</groupId>
            <artifactId>zeabay-ops</artifactId>
        </dependency>
        <dependency>
            <groupId>com.zeabay</groupId>
            <artifactId>zeabay-core</artifactId>
        </dependency>
        <dependency>
            <groupId>com.zeabay</groupId>
            <artifactId>zeabay-logging</artifactId>
        </dependency>
        <dependency>
            <groupId>com.zeabay</groupId>
            <artifactId>zeabay-r2dbc</artifactId>
        </dependency>
        <dependency>
            <groupId>com.zeabay</groupId>
            <artifactId>zeabay-validation</artifactId>
        </dependency>
        <dependency>
            <groupId>com.zeabay</groupId>
            <artifactId>zeabay-kafka</artifactId>
        </dependency>
        <dependency>
            <groupId>com.zeabay</groupId>
            <artifactId>zeabay-outbox</artifactId>
        </dependency>
        <dependency>
            <groupId>com.zeabay</groupId>
            <artifactId>zeabay-inbox</artifactId>
        </dependency>
        <dependency>
            <groupId>com.zeabay</groupId>
            <artifactId>zeabay-redis</artifactId>
        </dependency>
        <dependency>
            <groupId>com.zeabay</groupId>
            <artifactId>zeabay-security</artifactId>
        </dependency>

        <!-- Security — JWT resource server -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-security</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-oauth2-resource-server</artifactId>
        </dependency>

        <!-- Object Storage — centralized S3/MinIO client via zeabay-s3 -->
        <dependency>
            <groupId>com.zeabay</groupId>
            <artifactId>zeabay-s3</artifactId>
        </dependency>

        <!-- Mapping -->
        <dependency>
            <groupId>org.mapstruct</groupId>
            <artifactId>mapstruct</artifactId>
        </dependency>
        <dependency>
            <groupId>org.mapstruct</groupId>
            <artifactId>mapstruct-processor</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- Lombok -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>

        <!-- Observability -->
        <dependency>
            <groupId>io.micrometer</groupId>
            <artifactId>micrometer-tracing-bridge-otel</artifactId>
        </dependency>
        <dependency>
            <groupId>io.opentelemetry</groupId>
            <artifactId>opentelemetry-exporter-otlp</artifactId>
        </dependency>

        <dependency>
            <groupId>me.paulschwarz</groupId>
            <artifactId>springboot4-dotenv</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <executions>
                    <execution>
                        <id>build-info</id>
                        <phase>process-resources</phase>
                        <goals>
                            <goal>build-info</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.flywaydb</groupId>
                <artifactId>flyway-maven-plugin</artifactId>
                <version>10.20.1</version>
                <configuration>
                    <url>jdbc:postgresql://localhost:5432/pulse</url>
                    <user>pulse</user>
                    <password>pulse</password>
                    <schemas>
                        <schema>profile</schema>
                    </schemas>
                    <locations>
                        <location>classpath:db/migration</location>
                        <location>classpath:com/zeabay/common/outbox/db/migration</location>
                    </locations>
                </configuration>
            </plugin>
        </plugins>
    </build>

</project>
