# -------------------------------------------------------------------------------------------------
# BACKEND UYGULAMALARI — auth-service, mail-service vb. için (pulse-backend dizininde kullanılır)
# -------------------------------------------------------------------------------------------------
# Infra değişkenleri (POSTGRES_*, REDIS_*, KAFKA_*) için infra/local/.env kullanın.
# Bu dosyayı .env olarak kopyalayıp düzenleyin: cp .env.example .env

# Mail (Gmail SMTP — mail-service için)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-gmail@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM=your-gmail@gmail.com
